---
import AdjustText from './AdjustText.astro';
import {
  SITE_TITLE,
  POSTS_TITLE,
  ACTIVITIES_TITLE,
  TAGS_TITLE,
} from '../consts';
---

<>
  <header>
    <div class="header-content">
      <a class="title" href="/">
        <AdjustText text={SITE_TITLE} />
      </a>
      <nav>
        <ul>
          <li>
            <a class="nav-item" href="/posts/">
              <AdjustText text={POSTS_TITLE} />
            </a>
          </li>
          <li>
            <a class="nav-item" href="/activities/">
              <AdjustText text={ACTIVITIES_TITLE} />
            </a>
          </li>
          <li>
            <a class="nav-item" href="/tags/">
              <AdjustText text={TAGS_TITLE} />
            </a>
          </li>
        </ul>
      </nav>
    </div>
    <hr />
  </header>
</>

<style lang="scss">
  header {
    .header-content {
      display: flex;
      align-items: baseline;
      margin: 0 auto;
      padding: 24px 0 18px 0;
      width: calc(min(100%, dimensions.$screen-wrapper-max) - 32px);

      a {
        color: inherit;
        text-decoration: none;
        border-radius: 2px;

        @media (hover: hover) {
          &:hover {
            color: colors.$color-link;
            outline: 1px dashed;
          }
        }

        &:active {
          color: colors.$color-link;
          outline: 1px solid;
        }
      }

      .title {
        font: typography.$font-title-medium;
        margin-bottom: 6px;
      }

      nav {
        font: typography.$font-label-large;
        margin-left: auto;

        ul {
          display: flex;

          li:not(:first-child) {
            margin-left: 12px;
          }

          .nav-item {
            display: inline;

            @media (hover: hover) {
              &:hover {
                color: colors.$color-link;
                outline: 1px dashed;

                &::before {
                  background-color: colors.$color-link;
                }
              }
            }

            &:active {
              color: colors.$color-link;
              outline: 1px solid;

              &::before {
                background-color: colors.$color-link;
              }
            }
          }
        }
      }
    }
  }
</style>
