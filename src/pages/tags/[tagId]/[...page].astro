---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContentsPage from '../../../components/ContentsPage.astro';
import { type ContentSummary } from '../../../models/contentSummary';
import { type Tag } from '../../../models/tag';
import { ACTIVITIES } from '../../../activities';
import { PAGE_SIZE } from '../../../consts';

type Props = {
  tag: Tag;
  pageLength: number;
  contents: ContentSummary[];
};

export async function getStaticPaths() {
  const posts: ContentSummary[] = (await getCollection('posts')).map((post) => {
    return {
      platform: null,
      title: post.data.title,
      description: post.data.description,
      publishedDate: post.data.publishedDate,
      tags: post.data.tags,
      url: `/posts/${post.id}/`,
    };
  });
  const activities: ContentSummary[] = ACTIVITIES.map((activity) => {
    return {
      platform: activity.platform,
      title: activity.title,
      description: activity.description,
      publishedDate: new Date(activity.publishedDate),
      tags: activity.tags,
      url: activity.url,
    };
  });
  const contents = [...posts, ...activities].sort((a, b) =>
    a.publishedDate > b.publishedDate ? -1 : 1,
  );
  const tags = (() => {
    const tags: Set<Tag> = new Set();
    contents.forEach((content) => {
      content.tags?.forEach((tag) => tags.add(tag));
    });
    return Array.from(tags.values());
  })();
  const ret: {
    params: { tagId: string; page: string | undefined };
    props: Props;
  }[] = [];
  tags.forEach((tag) => {
    const filteredContents = contents.filter((content) =>
      content.tags?.map((tag) => tag.id)?.includes(tag.id),
    );
    const pageLength = Math.ceil(filteredContents.length / PAGE_SIZE);
    for (let i = 0; i < pageLength; i++) {
      ret.push({
        params: {
          tagId: tag.id,
          page: i === 0 ? undefined : String(i + 1),
        },
        props: {
          tag: tag,
          pageLength: pageLength,
          contents: filteredContents.slice(i * PAGE_SIZE, (i + 1) * PAGE_SIZE),
        },
      });
    }
  });
  return ret;
}

const { page: _page } = Astro.params;
const { tag, pageLength, contents } = Astro.props;
const page = _page ? Number(_page) : 1;
---

<>
  <BaseLayout title={tag.name}>
    <ContentsPage
      title={tag.name}
      contents={contents}
      page={page}
      pageLength={pageLength}
      baseUrl=`/tags/${tag.id}/`
    />
  </BaseLayout>
</>
