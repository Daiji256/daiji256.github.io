---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContentsPage from '../../components/ContentsPage.astro';
import { type ContentSummary } from '../../models/contentSummary';
import { ACTIVITIES } from '../../activities';
import { ACTIVITIES_TITLE, PAGE_SIZE } from '../../consts';

type Props = {
  pageLength: number;
  activities: ContentSummary[];
};

export async function getStaticPaths() {
  const activities: ContentSummary[] = ACTIVITIES.map((activity) => {
    return {
      platform: activity.platform,
      title: activity.title,
      description: activity.description,
      publishedDate: new Date(activity.publishedDate),
      tags: activity.tags,
      url: activity.url,
    };
  }).sort((a, b) => (a.publishedDate > b.publishedDate ? -1 : 1));
  const pageLength = Math.ceil(activities.length / PAGE_SIZE);
  const ret: {
    params: { page: string | undefined };
    props: Props;
  }[] = [];
  for (let i = 0; i < pageLength; i++) {
    ret.push({
      params: { page: i === 0 ? undefined : String(i + 1) },
      props: {
        pageLength: pageLength,
        activities: activities.slice(i * PAGE_SIZE, (i + 1) * PAGE_SIZE),
      },
    });
  }
  return ret;
}

const { page: _page } = Astro.params;
const { pageLength, activities } = Astro.props;
const page = _page ? Number(_page) : 1;
---

<>
  <BaseLayout title={ACTIVITIES_TITLE}>
    <ContentsPage
      title={ACTIVITIES_TITLE}
      contents={activities}
      page={page}
      pageLength={pageLength}
      baseUrl="/activities/"
    />
  </BaseLayout>
</>
